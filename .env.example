# Copy this file to .env (which is gitignored) and fill in real values.
# Used by scripts/refresh_gbif_data.py to authenticate with the GBIF API.
#
# Create / manage your GBIF account at https://www.gbif.org/user/profile

GBIF_USER=your-gbif-username
GBIF_PASSWORD=your-gbif-password

# Optional: an email GBIF will use for notifications. If empty, no email is sent.
GBIF_NOTIFY_EMAIL=
